1. Total Drivers = DISTINCTCOUNT(monthly_activity[driver_id])
2. Churn Driver = CALCULATE(DISTINCTCOUNT(monthly_activity[driver_id]),monthly_activity[churned]=1)
3. Active Drivers = [Total Drivers] - [Churned Drivers]
4. Churn Status = IF(monthly_activity[churned]=1,"Churned","Active")
5. Avg Earnings = AVERAGE(monthly_activity[earnings])
6. Avg Rides = AVERAGE(monthly_activity[rides_completed])
7. Avg Login Hours = AVERAGE(monthly_activity[login_hours])
8. Churn Status = IF(monthly_activity[churned]=1,"Churned","Active")
9. Cohort size = [Total Driver]-[Churn Driver]
11. Total Cohort = DISTINCTCOUNT(monthly_activity[cohort index])
12. Retention Rate = DIVIDE(monthly_activity[Cohort size],[Total Driver],0)
13. cohort index = DATEDIFF(RELATED(driver_master[join_date]),monthly_activity[month], MONTH)
14. Avg 3 month Retention = CALCULATE([Retention Rate], monthly_activity[cohort index]=3)
15. Avg 6 month Retention = CALCULATE([Retention Rate], monthly_activity[cohort index]=6)
16. Risk Segmentation = SWITCH(TRUE(),monthly_activity[inactive_days]>15,"High Risk", monthly_activity[inactive_days]>7, "Medium Risk", "Low Risk")
